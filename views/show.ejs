<% layout("/layouts/boilerplate.ejs")%>
<body>
     <h3><%= listing.title %></h3>
     <div class="row">
      <div class="col-8 offset-2">
     <div class="card listing-card" >
      </div>
      <div class="col-8 offset-2">
  <img src="<%=listing.image.url %>" class="card-img-top show-img" alt="...">
  <div class="card-body">
    <p class="card-text">
      
   <i> Owned By:<%= listing.owner.username%><br></i> 
   
    <%= listing.description %><br>
    &#8377;<%= listing.price.toLocaleString("en-IN") %><br>
    <%= listing.location %><br>
    <%= listing.country %><br>
    </p>
  </div>

  
</div>

<a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">Edit the listing</a>

   
 <form method="post" action="/listings/<%=listing._id %>?_method=DELETE">
  <button class="btn btn-dark mb-3 mt-3 ">Delete</button>
 </form>

    
    </div>
<hr>

    <div class="mb-3 mt-3 col-8 offset-2">
      <% if(currUser) { %>
        <h4> All Reviews</h4>
    <form method="post" action="/listings/<%= listing._id%>/reviews" novalidate class="needs-validation"">
      <!-- <div mb-3>
        <label for="rating" class="form-label" min="1" max="5">Rating</label>
        <input type="number" name="rating" id="rating" class="form-control" required>
         <div class="invalid-feedback">please enter Rating</div>
      </div> -->
           <div mb-3>
              <label for="rating" class="form-label" min="1" max="5">Rating</label>
<fieldset class="starability-slot">

 
  <input type="radio" id="no-rate" class="input-no-rate" name="rating" value="0" checked aria-label="No rating." />
  <input type="radio" id="first-rate1" name="rating" value="1" />
  <label for="first-rate1" title="Terrible">1 star</label>
  <input type="radio" id="first-rate2" name="rating" value="2" />
  <label for="first-rate2" title="Not good">2 stars</label>
  <input type="radio" id="first-rate3" name="rating" value="3" />
  <label for="first-rate3" title="Average">3 stars</label>
  <input type="radio" id="first-rate4" name="rating" value="4" />
  <label for="first-rate4" title="Very good">4 stars</label>
  <input type="radio" id="first-rate5" name="rating" value="5" />
  <label for="first-rate5" title="Amazing">5 stars</label>
</fieldset>
</div>

      <div mb-3>
        <label for="comment" class="form-label">Comment</label>
        <textarea name="comment" id="comment" class="form-control" rows="30" cols="50" required></textarea>
         <div class="invalid-feedback">please enter comment</div>
      </div>

      <button class="btn btn-dark mb-3 mt-3 ">Submit</button>
     </form>
     <% } %>
    


    
    

    <div class="row">
<% for(review of listing.reviews) {  %> 

    <div class="card  col-5 ms-3  mb-3 ">
      <div class="card-body">
        <div class="card-title">@<%=review.author.username%></div>
        <div class="card-text">
           
       
          <p class="starability-result" data-rating="<%=review.rating %>"></p>
          <p><%= review.comment %></p>
      </div>
      </div>
      <form class="mb-3" method="post" action="/listings/<%=listing._id%>/reviews/<%=review._id%>?_method=DELETE">
        <button class="btn btn-dark">Delete</button>
      </form>
      
    </div>
    <%  }%>

    </div>

    </div>
     
</body>
