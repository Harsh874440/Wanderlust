<% layout("/layouts/boilerplate.ejs")%>
<body>
    <div class="row">
        <div class="col-8 offset-2">
    <form method="post" action="/listings/<%=listing._id %>?_method=PATCH">
        <div>
             <label for="title" class="form-label">Title</label>
 <input type="text" value="<%= listing.title %>" name="title" class="form-control"><br>
        </div>
       <div>
        <label for="description" class="form-label">Description</label>
<textarea name="description" value="<%= listing.description %>" class="form-control"></textarea><br>
       </div>
        <div>
            <label for="image" class="form-label">Image</label>
 <input type="text" value="<%= listing.image.url %>" name="image" class="form-control"><br>
        </div>
       <div>
        <label for="price" class="form-label">Price</label>
 <input type="number" value="<%= listing.price %>" name="price" class="form-control"><br>
       </div>
       <div>
        <label for="location" class="form-label">Location</label>
<input type="text" value="<%= listing.location %>" name="location" class="form-control"><br>
       </div>
        <div>
            <label for="country" class="form-label">Country</label>
<input type="text" value="<%= listing.country %>" name="country" class="form-control"><br>
        </div>
        
        <button class="btn btn-dark add-btn">Submit</button>
        <br><br>
    </form>

    </div>
    </div>
</body>
